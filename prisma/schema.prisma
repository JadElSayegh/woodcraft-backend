generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(USER)
  refreshHash  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model HomepageContent {
  id           String @id @default(uuid())
  singletonKey String @unique @default("homepage")

  heroTitle      String
  heroSubtitle   String?
  heroButtonText String?
  heroButtonLink String?

  heroBackgroundImage String?
  heroImageOne        String?
  heroImageTwo        String?
  heroImageThree      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TextSection {
  id        String   @id @default(uuid())
  title     String
  content   String
  image     String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WoodType {
  id       String  @id @default(uuid())
  name     String
  image    String?
  order    Int     @default(0)
  isActive Boolean @default(true)

  characteristics WoodCharacteristic[]
  priceGroups     WoodPriceGroup[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WoodCharacteristic {
  id         String  @id @default(uuid())
  woodTypeId String
  text       String
  isPositive Boolean @default(true)
  order      Int     @default(0)

  woodType WoodType @relation(fields: [woodTypeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([woodTypeId])
}

model WoodPriceGroup {
  id         String @id @default(uuid())
  woodTypeId String

  height     Decimal @db.Decimal(10, 2)
  thickness  Decimal @db.Decimal(10, 2)
  pricePerM3 Decimal @db.Decimal(12, 2)

  woodType WoodType           @relation(fields: [woodTypeId], references: [id], onDelete: Cascade)
  variants WoodPriceVariant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([woodTypeId])
}

model WoodPriceVariant {
  id               String @id @default(uuid())
  woodPriceGroupId String

  length        Decimal @db.Decimal(10, 2)
  volumeM3      Decimal @db.Decimal(12, 6)
  pricePerPiece Decimal @db.Decimal(12, 2)
  order         Int     @default(0)

  priceGroup WoodPriceGroup @relation(fields: [woodPriceGroupId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([woodPriceGroupId])
}

model ProductPhoto {
  id        String   @id @default(uuid())
  image     String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
